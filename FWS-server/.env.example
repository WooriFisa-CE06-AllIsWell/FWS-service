# ============================================================
# FWS Backend 환경변수 예시
# 이 파일을 복사해서 .env 로 저장 후 실제 값으로 채우세요.
# cp .env.example .env
# ============================================================

MOCK_MODE=false

VCENTER_HOST=172.18.0.XXX
VCENTER_USER=administrator@vcenter.yourname.vcsa
VCENTER_PASSWORD=your_password
VCENTER_VERIFY_SSL=false

TEMPLATE_UBUNTU=vm-XX
TEMPLATE_ROCKY=vm-XX

CLUSTER=domain-cXX
DATASTORE=datastore-XX
VM_FOLDER=group-vXX

GUACAMOLE_URL=http://192.168.X.X:8080
GUACAMOLE_USER=admin
GUACAMOLE_PASSWORD=your_password

VM_SSH_PASSWORD=your_vm_password

CORS_ORIGINS=*
